    {
      "@type": "Question",
      "name": "What food is available at breakfast?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Breakfast includes Indonesian favorites (nasi goreng, fried noodles, local dishes) and some international options. Guests describe the variety as decent with multiple choices."
